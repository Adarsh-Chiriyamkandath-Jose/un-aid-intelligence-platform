DATABASE_URL=postgresql://your_username:your_password@localhost/unaid_db
# 🔐 OpenAI GPT key (required for AI assistant)
OPENAI_API_KEY=your_openai_api_key_here

# 🔐 Mapbox API key (required for map visualization)
# NOTE: the client reads this via Vite, so it MUST be prefixed with VITE_.
# In production, set this in your Vercel project Environment Variables and redeploy.
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# 🧪 React/Vite environment
NODE_ENV=development
# Replace with your own credentials before running locally
